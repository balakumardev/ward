{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ward",
  "version": "0.1.0",
  "identifier": "dev.balakumar.ward",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ward",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "© 2026 Bala Kumar",
    "shortDescription": "A native macOS command center for AI coding tool config",
    "longDescription": "Ward organizes the configuration of Claude Code and Codex CLI from one window: skills, memories, MCP servers, agents, hooks, commands, plans, rules, and settings — across global and project scopes. It adds an integrated MCP security scanner, a context-window budget view, session tools, and a git-backed backup center, plus a background menu-bar agent that runs scheduled scans and fires native notifications.",
    "targets": ["dmg", "app"],
    "publisher": "Bala Kumar",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "dmg": {
        "background": null,
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "resources": [],
    "externalBin": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
